{
  "name": "velowind-app-dev-test",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "appium:ios:test": "pnpm appium:ios:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_ios_tests -m smoke",
    "appium:ios:test:local:publish": "pnpm appium:ios:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_ios_tests --suite apps/velowind-app/appium/test-suites/ios-message-publish.yaml",
    "appium:ios:test:local:publish_note": "pnpm appium:ios:test:local:publish",
    "appium:ios:test:full": "pnpm appium:ios:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_ios_tests --all",
    "appium:ios:test:suite": "pnpm appium:ios:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_ios_tests --suite",
    "appium:ios:config-test": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m pytest apps/velowind-app/appium/tests/unit-test/test_config.py -q",
    "appium:ios:preflight": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.preflight",
    "appium:ios:record": "pnpm appium:ios:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.ios_manual_recording",
    "appium:ios:record:generate": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.generate_ios_test_from_recording",
    "appium:ios:allure:generate": "allure generate .tmp/appium-ios/allure-results --clean -o .tmp/appium-ios/allure-report",
    "appium:ios:allure:open": "allure open .tmp/appium-ios/allure-report",
    "appium:android:test": "pnpm appium:android:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_android_tests -m android_smoke",
    "appium:android:media:export": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.mac_photos_export",
    "appium:android:media:sync": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.android_media_sync",
    "appium:android:test:local": "sh ./scripts/appium-android-local.sh local",
    "appium:android:test:local:publish": "sh ./scripts/appium-android-local.sh publish",
    "appium:android:test:local:publish_note": "pnpm appium:android:test:local:publish",
    "appium:android:test:local:activity_publish": "sh ./scripts/appium-android-local.sh activity-publish",
    "appium:android:test:local:activity_session": "sh ./scripts/appium-android-local.sh activity-session",
    "appium:android:test:local:rental_order": "sh ./scripts/appium-android-local.sh rental-order",
    "appium:android:test:full": "pnpm appium:android:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_android_tests --all",
    "appium:android:test:suite": "pnpm appium:android:preflight && PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.run_android_tests --suite",
    "appium:android:config-test": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m pytest apps/velowind-app/appium/tests/unit-test/test_android_config.py apps/velowind-app/appium/tests/unit-test/test_run_android_tests.py apps/velowind-app/appium/tests/unit-test/test_android_preflight.py -q",
    "appium:android:preflight": "PYTHONPATH=apps/velowind-app/appium ./.venv/bin/python -m velowind_appium.android_preflight",
    "appium:android:allure:generate": "allure generate .tmp/appium-android/allure-results --clean -o .tmp/appium-android/allure-report",
    "appium:android:allure:open": "allure open .tmp/appium-android/allure-report"
  },
  "packageManager": "pnpm@9.0.0"
}
